	Wave
	{
		InitWaveOutput
		{
			Target BigNet
			Action RunScriptCode
			Param "
				// Load popextensions script
				IncludeScript(`popextensions_main.nut`, getroottable())
				
				EntFire(`wave_init_relay`, `Trigger`)
								
				::SimplePlay <- function( value ) {
					PrecacheScriptSound( value )
					PrecacheSound( value )
					local max = MaxClients().tointeger()
					for (local i = 1; i <= max; i++) {
						local p = PlayerInstanceFromIndex(i)
						
						if (p && p.IsValid()) {
							EmitSoundEx({
								sound_name = value,
								entity = p,
								channel = 6,
								sound_level = 0,
								volume = 1.0,
								flags = 0
							})
						}
					}
				}
				
				function Detonation() {
					EntFire(`boss_deploy_relay`, `Trigger`)
				}
				
				MissionAttrs({
					WaveStartCountdown = 7
					SoundLoop = {
						Wave = {
							Order = `list`
							`1` : {
								Sound = `#reflections_of_violence.mp3`
								Volume = 1
								Duration = 305
							}
						}
					}
				})
			"
		}
		StartWaveOutput
		{
			Target BigNet
			Action RunScriptCode
			Param "
				// Load popextensions script
				IncludeScript(`popextensions_main.nut`, getroottable())
				
				EntFire(`wave_start_relay`, `Trigger`)
				
				MissionAttrs({
					Timer = {
						Style = [`Clock`, `game_text`, `-1 0.25`]
						Minutes = 5
						End = {
							Action = Detonation
						}
					}
				})
				
				ClientPrint( null, HUD_PRINTCENTER, `THE MOTHERSHIP HAS ACTIVATED THE EMERGENCY WARHEAD.` )
				PopExtUtil.RunWithDelay(2, function() { ClientPrint( null, 4, `THE MOTHERSHIP HAS ACTIVATED THE EMERGENCY WARHEAD.`) })
				PopExtUtil.RunWithDelay(6, function() { ClientPrint( null, 4, `THE LAST CHAMPION HAS ARRIVED TO PREVENT YOUR ESCAPE.`) })
				PopExtUtil.RunWithDelay(10, function() { ClientPrint( null, 4, `GIVE A WARM WELCOME TO...`) })
				PopExtUtil.RunWithDelay(14, function() { ClientPrint( null, 4, `T H E  A I R B O R N E  R E G E N T .`) })
				PopExtUtil.RunWithDelay(14, function() { ::SimplePlay(`Soldier.M_MVM_LaughEvil02`) })
			"
		}
